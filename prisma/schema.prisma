model members_member {
  id        BigInt @id @default(autoincrement())
  firstname String @db.VarChar(255)
  lastname  String @db.VarChar(255)
  email     String @unique(map: "email") @db.VarChar(254)
  phone     String @db.VarChar(20)
  address   String @db.VarChar(255)
}

model site_settings_sitesettings {
  id               BigInt  @id @default(autoincrement())
  site_title       String? @db.VarChar(255)
  site_description String? @db.LongText
  logo             String? @db.VarChar(100)
  fav_icon         String? @db.VarChar(100)
  email            String? @db.VarChar(254)
  phone            String? @db.VarChar(20)
  address          String? @db.VarChar(255)
  facebook_url     String? @db.VarChar(255)
  instagram_url    String? @db.VarChar(255)
  twitter_url      String? @db.VarChar(255)
}
